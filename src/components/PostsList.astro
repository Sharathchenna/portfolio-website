---
const posts = [
  {
    id: "first-post",
    title: "Welcome to the Placeholder Blog",
    date: "2025-04-01",
    sup: "NEW",
  },
  {
    id: "second-post",
    title: "How to Build a Portfolio Site",
    date: "2025-03-15",
    sup: "",
  },
  {
    id: "third-post",
    title: "Astro vs. Other Static Site Generators",
    date: "2025-02-28",
    sup: "",
  },
];
function formatDate(date: string | Date) {
  // Simple date formatting for placeholder
  return new Date(date).toLocaleDateString(undefined, { year: "numeric", month: "short", day: "numeric" });
}
---

<ul class="!pl-0 dashed">
  {
    posts.map((post) => (
      <li>
        <a class="!decoration-none" href={`/posts/${post.id}`}>
          {post.title}
          {post.sup ? <sup class="italic text-orange-11">{post.sup}</sup> : null}
        </a>
        <div class="dash" />
        <div class="text-gray-11">{formatDate(post.date)}</div>
      </li>
    ))
  }
</ul>
