---
import '../styles/base.css';
import '../styles/font-fallbacks.css';
import '../styles/shiki.css';
import '../styles/prose.css';

import Fonts from '../components/Fonts.astro';
import ThemeScript from '../components/ThemeScript.astro';

export type Props = {
  title?: string;
  description?: string;
};
const { ...meta } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{meta.title ?? "Placeholder Site"}</title>
    <ThemeScript />
    <Fonts />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <slot name="head" />
  </head>
  <body class="font-serif antialiased text-xl leading-normal bg-gray-1 text-gray-12 w-full h-full">
    <slot />
  </body>
</html>
