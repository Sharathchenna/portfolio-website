---
import MainLayout from '../layouts/MainLayout.astro'
import LinkIcons from '../components/LinkIcons.astro'
import PerusalList from '../components/PerusalList.astro'
import PostsList from '../components/PostsList.astro'
import ProjectsList from '../components/ProjectsList.astro'
import Sidenote from '../components/Sidenote.astro'
import avatarImg from '../assets/avatar.svg'
import flowersImg from '../assets/flowers.svg'

const websiteMeta = {
  title: "Placeholder Portfolio",
  description: "A demo portfolio site built with Astro and placeholder content.",
  links: {
    github: "placeholder",
    twitter: "placeholder",
    email: "hello@example.com",
    rss: "#"
  }
}
---

<MainLayout title={websiteMeta.title} description={websiteMeta.description}>
  <Fragment slot="aside-left">
    <div class="flex-1"></div>
    <div class="hidden xl:block px-10 pb-10">
      <LinkIcons links={websiteMeta.links} />
    </div>
  </Fragment>

  <Fragment slot="title">
    <div class="flex flex-row items-end gap-5 pb-5 xl:pb-10">
      <img src={avatarImg.src} class="h-20 w-auto aspect-square" alt="Avatar" />
      <div class="flex flex-col">
        <h2 class="font-semibold text-2xl">{websiteMeta.title}</h2>
        <div class="flex flex-row items-center gap-2.5 text-gray-11 font-sans">
          <span>{websiteMeta.description}</span>
        </div>
      </div>
    </div>
  </Fragment>

  <Fragment slot="article">
    <Sidenote refback>
      <blockquote>
        This is a placeholder site. <a href="#">Learn more about the template</a>.
      </blockquote>
    </Sidenote>

    <h3>Posts</h3>
    <PostsList />
    <p class="text-gray-11">
      See <a href="#">/micro</a> for more frequent updates.
    </p>

    <h3>Projects</h3>
    <Sidenote side="left">
      <p>
        <span class="inline xl:hidden">Featuring a</span>
        <span class="hidden xl:inline">A</span> few screengrabs from some recent <em>demo</em> works.
      </p>
    </Sidenote>
    <ProjectsList />
    <h3>Perusal</h3>
    <Sidenote>
      <p>Things I've read or been reading lately.</p>
    </Sidenote>
    <PerusalList />
  </Fragment>

  <Fragment slot="footnotes">
    <div class="h-20"></div>
    <div class="w-full flex flex-row items-end justify-between">
      <div class="flex flex-col gap-5 xl:gap-0">
        <div class="prose">
          <a href="#" class="italic">Handcrafted</a> by <a href="#">Placeholder</a>.
        </div>
        <div class="text-gray-11 hidden xl:block">I love sidenotes, can you tell?</div>
        <div class="block xl:hidden"><LinkIcons links={websiteMeta.links} /></div>
      </div>
      <img src={flowersImg.src} class="h-25 w-auto text-gray-11 mb-2.5 hidden xl:block" alt="Decoration" />
    </div>
  </Fragment>
</MainLayout>
