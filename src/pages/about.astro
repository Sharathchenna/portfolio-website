---
import { getEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import MainLayout from '@/layouts/MainLayout.astro';
import Sidenote from '@/components/Sidenote.astro';

// Get website metadata
const websiteEntry = await getEntry('website', 'meta');
const websiteMeta = websiteEntry || {
  data: {
    title: "Sharath Chenna",
    description: "Software Developer & Designer",
    links: {}
  }
};

// Define the skill type
type Skill = {
  name: string;
  category: string;
};

// Get skills collection - skills is now an array in a data collection
const skillsCollection = await getCollection('skills');

// Extract skills array or use empty array if not found
const skillsData = skillsCollection.length > 0 ? skillsCollection[0].data : [];
const skills = Array.isArray(skillsData) ? skillsData as Skill[] : [];

// Group skills by category
const skillsByCategory = skills.reduce((acc: Record<string, Skill[]>, skill: Skill) => {
  const { category } = skill;
  if (!acc[category]) {
    acc[category] = [];
  }
  acc[category].push(skill);
  return acc;
}, {} as Record<string, Skill[]>);
---

<MainLayout title="About | Sharath Chenna" description="Learn more about Sharath Chenna and his experience">
  <Fragment slot="title">
    <div class="pb-5">
      <h1 class="text-3xl font-semibold">About Me</h1>
    </div>
  </Fragment>

  <Fragment slot="article">
    <section class="mb-8">
      <p class="mb-4">
        Hello! I'm Sharath, a passionate software developer with a love for creating elegant, efficient, and user-friendly applications. I specialize in modern web technologies and enjoy solving complex problems with clean, maintainable code.
      </p>
      <p>
        With several years of experience in the tech industry, I've worked on a diverse range of projects from small startups to enterprise-level applications. My approach combines technical expertise with a strong focus on user experience and business needs.
      </p>
    </section>

    <h2 class="text-2xl font-semibold mb-4">Experience</h2>
    <section class="mb-8">
      <div class="border-l-2 border-gray-6 pl-4 space-y-6">
        <div>
          <h3 class="font-medium text-xl">Senior Software Developer</h3>
          <p class="text-gray-11">Company Name • 2021 - Present</p>
          <ul class="list-disc pl-5 mt-2">
            <li>Lead development of the company's flagship web application</li>
            <li>Implemented modern front-end architecture using React and TypeScript</li>
            <li>Improved application performance by 40% through optimization techniques</li>
            <li>Mentored junior developers and conducted code reviews</li>
          </ul>
        </div>
        <div>
          <h3 class="font-medium text-xl">Full Stack Developer</h3>
          <p class="text-gray-11">Previous Company • 2018 - 2021</p>
          <ul class="list-disc pl-5 mt-2">
            <li>Developed and maintained multiple client projects</li>
            <li>Built RESTful APIs using Node.js and Express</li>
            <li>Integrated various third-party services and payment gateways</li>
            <li>Collaborated with design team to implement responsive UI designs</li>
          </ul>
        </div>
      </div>
    </section>

    <h2 class="text-2xl font-semibold mb-4">Skills</h2>
    <section class="mb-8">
      <Sidenote>
        <p>I'm always learning and adding to my technical toolkit.</p>
      </Sidenote>
      
      {Object.entries(skillsByCategory).map(([category, skills]) => (
        <div class="mb-6">
          <h3 class="text-xl font-medium capitalize mb-3">{category}</h3>
          <div class="flex flex-wrap gap-2">
            {skills.map((skill: Skill) => (
              <span class="px-3 py-1 bg-gray-3 rounded-full text-sm">{skill.name}</span>
            ))}
          </div>
        </div>
      ))}
    </section>

    <h2 class="text-2xl font-semibold mb-4">Education</h2>
    <section class="mb-8">
      <div class="border-l-2 border-gray-6 pl-4 space-y-4">
        <div>
          <h3 class="font-medium text-xl">Master's in Computer Science</h3>
          <p class="text-gray-11">University Name • 2016 - 2018</p>
        </div>
        <div>
          <h3 class="font-medium text-xl">Bachelor's in Computer Engineering</h3>
          <p class="text-gray-11">University Name • 2012 - 2016</p>
        </div>
      </div>
    </section>

    <h2 class="text-2xl font-semibold mb-4">Contact</h2>
    <section>
      <p>
        I'm always open to discussing new projects, creative ideas, or opportunities to be part of your vision. Feel free to reach out through any of the social links or via email at <a href="mailto:email@example.com" class="text-blue-11 hover:underline">email@example.com</a>.
      </p>
    </section>
  </Fragment>
</MainLayout> 