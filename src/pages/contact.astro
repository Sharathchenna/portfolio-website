---
import { getEntry } from 'astro:content';
import MainLayout from '@/layouts/MainLayout.astro';
import Sidenote from '@/components/Sidenote.astro';

// Get website metadata
const websiteEntry = await getEntry('website', 'meta');
const websiteMeta = websiteEntry || {
  data: {
    title: "Sharath Chenna",
    description: "Software Developer & Designer",
    links: {}
  }
};
---

<MainLayout title="Contact | Sharath Chenna" description="Get in touch with Sharath Chenna">
  <Fragment slot="title">
    <div class="pb-5">
      <h1 class="text-3xl font-semibold">Contact Me</h1>
    </div>
  </Fragment>

  <Fragment slot="article">
    <section class="mb-8">
      <p class="mb-4">
        I'm always open to discussing new projects, creative ideas, or opportunities to be part of your vision.
      </p>
      
      <Sidenote>
        <p>
          You can also reach me directly through any of my social media profiles.
        </p>
      </Sidenote>
    </section>

    <div class="bg-gray-2 p-6 rounded-lg mb-8">
      <h2 class="text-2xl font-medium mb-4">Send a Message</h2>
      <form class="space-y-4">
        <div>
          <label for="name" class="block mb-1">Name</label>
          <input 
            type="text" 
            id="name" 
            name="name" 
            class="w-full px-3 py-2 bg-gray-1 border border-gray-6 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-9"
            required
          />
        </div>
        
        <div>
          <label for="email" class="block mb-1">Email</label>
          <input 
            type="email" 
            id="email" 
            name="email" 
            class="w-full px-3 py-2 bg-gray-1 border border-gray-6 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-9"
            required
          />
        </div>
        
        <div>
          <label for="subject" class="block mb-1">Subject</label>
          <input 
            type="text" 
            id="subject" 
            name="subject" 
            class="w-full px-3 py-2 bg-gray-1 border border-gray-6 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-9"
            required
          />
        </div>
        
        <div>
          <label for="message" class="block mb-1">Message</label>
          <textarea 
            id="message" 
            name="message" 
            rows="5" 
            class="w-full px-3 py-2 bg-gray-1 border border-gray-6 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-9"
            required
          ></textarea>
        </div>
        
        <button 
          type="submit" 
          class="px-4 py-2 bg-blue-9 hover:bg-blue-10 text-white rounded-md transition-colors"
        >
          Send Message
        </button>
      </form>
    </div>

    <section>
      <h2 class="text-2xl font-medium mb-4">Other Ways to Connect</h2>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="border border-gray-6 p-4 rounded-lg">
          <h3 class="font-medium">Email</h3>
          <p class="text-gray-11 mt-1">
            <a href="mailto:email@example.com" class="text-blue-11 hover:underline">
              email@example.com
            </a>
          </p>
        </div>
        
        <div class="border border-gray-6 p-4 rounded-lg">
          <h3 class="font-medium">LinkedIn</h3>
          <p class="text-gray-11 mt-1">
            <a href="https://linkedin.com/in/yourusername" target="_blank" rel="noopener noreferrer" class="text-blue-11 hover:underline">
              linkedin.com/in/yourusername
            </a>
          </p>
        </div>
        
        <div class="border border-gray-6 p-4 rounded-lg">
          <h3 class="font-medium">GitHub</h3>
          <p class="text-gray-11 mt-1">
            <a href="https://github.com/yourusername" target="_blank" rel="noopener noreferrer" class="text-blue-11 hover:underline">
              github.com/yourusername
            </a>
          </p>
        </div>
        
        <div class="border border-gray-6 p-4 rounded-lg">
          <h3 class="font-medium">Twitter</h3>
          <p class="text-gray-11 mt-1">
            <a href="https://twitter.com/yourusername" target="_blank" rel="noopener noreferrer" class="text-blue-11 hover:underline">
              @yourusername
            </a>
          </p>
        </div>
      </div>
    </section>
  </Fragment>
</MainLayout>

<script>
  // Simple form validation and handling
  const form = document.querySelector('form');
  
  if (form) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      
      // In a real scenario, you would send the form data to a server
      // This is just a placeholder for demonstration
      alert('Thanks for your message! This is a demo form - in a real implementation, your message would be sent.');
      
      // Reset the form
      form.reset();
    });
  }
</script> 